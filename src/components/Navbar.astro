---
<!-- Navigation Header: Integrated Brand Palette Alignment -->
<header class="bg-white border-b border-neutral-100 py-4 sticky top-0 z-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex items-center justify-between">
    
    <!-- Left Section: Logo & Links -->
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
        <!-- Isotype [CG] - Pure Black Background for maximum contrast -->
        <div class="h-7 w-7 rounded bg-black flex items-center justify-center text-white font-bold text-xs tracking-tight">
          CG
        </div>
        <!-- Project Name -->
        <span class="text-xl font-bold text-black tracking-tight">Control de Gastos</span>
      </a>

      <!-- Navigation Links -->
      <nav class="hidden md:flex items-center gap-6">
        <a href="/" class="text-sm font-medium text-neutral-600 hover:text-black transition-colors">
          Inicio
        </a>
        <a href="/agencias" class="text-sm font-medium text-neutral-600 hover:text-black transition-colors">
          Agencias y Media Buyers
        </a>
      </nav>
    </div>

    <!-- Right Section: Aligned Teal Action Button -->
    <div class="flex items-center">
      <a 
        href="#directorios" 
        class="inline-flex items-center justify-center rounded-lg bg-[#0f9f90] px-4 py-2 text-sm font-semibold text-white shadow-xs hover:bg-[#0d877a] transition-colors"
      >
        Realizar Diagnóstico
      </a>
    </div>

  </div>
</header>