---
---
<footer class="bg-[#091e3a] text-slate-300 pt-16 pb-12 border-t border-slate-800">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Main Column Layout -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 pb-12 border-b border-slate-800">
      
      <!-- Column 1: Corporate Branding -->
      <div class="md:col-span-5 flex flex-col items-start space-y-4">
        <div class="flex items-center gap-2.5">
          <!-- Updated Isotype to match the main project identity -->
          <div class="h-7 w-7 rounded bg-white flex items-center justify-center text-black font-bold text-xs tracking-tight">
            CG
          </div>
          <div class="flex flex-col">
            <span class="text-lg font-bold text-white leading-none tracking-tight">Control de Gastos</span>
            <span class="text-[11px] text-teal-400 font-medium mt-0.5">Soluciones para empresas</span>
          </div>
        </div>
        <p class="text-sm text-slate-400 max-w-sm leading-relaxed">
          Directorio de soluciones de afiliación y control de gasto para empresas, agencias y profesionales.
        </p>
      </div>

      <!-- Column 2: Directories -->
      <div class="md:col-span-4 flex flex-col space-y-4">
        <h4 class="text-xs font-bold text-white uppercase tracking-wider">Directorios</h4>
        <ul class="space-y-2.5 text-sm">
          <li>
            <a href="/agencias" class="hover:text-teal-400 transition-colors">Agencias de paid media</a>
          </li>
          <li>
            <span class="text-slate-500 cursor-not-allowed flex items-center gap-1.5">
              Control de gasto interno <span class="text-[9px] bg-slate-800 text-slate-400 px-1.5 py-0.5 rounded">Próximamente</span>
            </span>
          </li>
          <li>
            <span class="text-slate-500 cursor-not-allowed flex items-center gap-1.5">
              Financiación empresarial <span class="text-[9px] bg-slate-800 text-slate-400 px-1.5 py-0.5 rounded">Próximamente</span>
            </span>
          </li>
        </ul>
      </div>

      <!-- Column 3: Legal Links -->
      <div class="md:col-span-3 flex flex-col space-y-4">
        <h4 class="text-xs font-bold text-white uppercase tracking-wider">Legal</h4>
        <ul class="space-y-2.5 text-sm">
          <li>
            <a href="/legal/privacidad" class="hover:text-teal-400 transition-colors">Privacidad</a>
          </li>
          <li>
            <a href="/legal/cookies" class="hover:text-teal-400 transition-colors">Cookies</a>
          </li>
          <li>
            <a href="/legal/aviso-legal" class="hover:text-teal-400 transition-colors">Aviso legal</a>
          </li>
          <li>
            <a href="/legal/afiliacion" class="hover:text-teal-400 transition-colors">Política de afiliación</a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom Block: Copyright & Affiliate Disclaimer -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-slate-400">
      <p>&copy; 2026 Control de Gastos. Todos los derechos reservados.</p>
      <p class="flex items-center gap-1 flex-wrap justify-center md:justify-end">
        Algunas soluciones pueden generarnos una comisión, sin coste adicional para ti.
        <a href="/legal/afiliacion" class="text-teal-400 hover:underline font-medium">Más info</a>
      </p>
    </div>

  </div>
</footer>