<div class="panel" style="padding: 24px;">
  <div class="quiz" id="quiz-app">
    <div>
      <div class="progress"><div class="progress-bar" id="progress-bar"></div></div>
      <p class="muted" id="quiz-step-label" style="margin-top:10px;">Paso 1 de 7</p>
    </div>

    <div id="quiz-question"></div>
    <div id="quiz-options" class="option-list"></div>

    <div class="quiz-actions">
      <button class="btn btn-secondary" id="prev-btn" type="button">Atrás</button>
      <button class="btn btn-primary" id="next-btn" type="button">Siguiente</button>
    </div>

    <div id="quiz-result" style="display:none;" class="result-box"></div>
  </div>
</div>

<script>
  const questions = [
    { q: "¿Trabajas como agencia, freelance o equipo interno?", options: ["Agencia", "Freelance", "Equipo interno"] },
    { q: "¿Cuántas personas gestionan campañas?", options: ["1-2", "3-5", "6 o más"] },
    { q: "¿Cuántas cuentas publicitarias administráis?", options: ["1-3", "4-10", "Más de 10"] },
    { q: "¿Cuánto gasto mensual en ads gestionáis aproximadamente?", options: ["Menos de 2.000€", "2.000€-10.000€", "Más de 10.000€"] },
    { q: "¿Compartís tarjetas entre varias personas?", options: ["Sí", "No"] },
    { q: "¿Necesitáis límites por cliente o por campaña?", options: ["Sí", "No"] },
    { q: "¿Tenéis problemas con aprobaciones o conciliación?", options: ["Sí", "No"] }
  ];

  const recommendations = [
    {
      title: "Tarjetas virtuales por campaña",
      text: "Útil si compartís tarjetas o necesitáis separar gasto entre clientes y cuentas."
    },
    {
      title: "Límites granulares por equipo",
      text: "Muy recomendable si gestionáis varias personas, cuentas o campañas al mismo tiempo."
    },
    {
      title: "Control operativo y conciliación",
      text: "Ideal si el problema principal es perder tiempo revisando y asignando gastos."
    }
  ];

  let current = 0;
  const answers = Array(questions.length).fill(null);

  const questionEl = document.getElementById("quiz-question");
  const optionsEl = document.getElementById("quiz-options");
  const resultEl = document.getElementById("quiz-result");
  const prevBtn = document.getElementById("prev-btn");
  const nextBtn = document.getElementById("next-btn");
  const bar = document.getElementById("progress-bar");
  const label = document.getElementById("quiz-step-label");

  function score() {
    let points = 0;
    if (answers[0] === "Agencia") points += 2;
    if (answers[1] === "3-5" || answers[1] === "6 o más") points += 1;
    if (answers[2] === "4-10" || answers[2] === "Más de 10") points += 1;
    if (answers[3] === "2.000€-10.000€" || answers[3] === "Más de 10.000€") points += 2;
    if (answers[4] === "Sí") points += 3;
    if (answers[5] === "Sí") points += 3;
    if (answers[6] === "Sí") points += 2;
    return points;
  }

  function render() {
    if (current >= questions.length) return showResult();

    const q = questions[current];
    questionEl.innerHTML = `<h3>${q.q}</h3>`;
    optionsEl.innerHTML = "";

    q.options.forEach((opt) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = `option ${answers[current] === opt ? "active" : ""}`;
      btn.textContent = opt;
      btn.onclick = () => {
        answers[current] = opt;
        render();
      };
      optionsEl.appendChild(btn);
    });

    prevBtn.disabled = current === 0;
    nextBtn.textContent = current === questions.length - 1 ? "Ver resultado" : "Siguiente";
    nextBtn.disabled = !answers[current];
    label.textContent = `Paso ${current + 1} de ${questions.length}`;
    bar.style.width = `${((current + 1) / questions.length) * 100}%`;
  }

  function showResult() {
    questionEl.style.display = "none";
    optionsEl.style.display = "none";
    prevBtn.style.display = "none";
    nextBtn.style.display = "none";
    label.textContent = "Resultado";

    const points = score();
    let main = recommendations[0];
    let secondary = recommendations[1];

    if (points >= 7) {
      main = recommendations[1];
      secondary = recommendations[2];
    }
    if (points >= 10) {
      main = recommendations[2];
      secondary = recommendations[0];
    }

    resultEl.style.display = "grid";
    resultEl.innerHTML = `
      <div class="card">
        <h3>Tu operativa muestra varios puntos de mejora</h3>
        <p>Por tus respuestas, parece que tu equipo necesita más control sobre pagos, límites y separación de gasto.</p>
      </div>
      <div class="card">
        <h3>${main.title}</h3>
        <p>${main.text}</p>
      </div>
      <div class="card">
        <h3>${secondary.title}</h3>
        <p>${secondary.text}</p>
      </div>
      <div class="card">
        <a class="btn btn-primary" href="https://example.com/affiliate-link" target="_blank" rel="noopener noreferrer">Ir a la solución recomendada</a>
      </div>
    `;
  }

  prevBtn.addEventListener("click", () => {
    if (current > 0) current--;
    render();
  });

  nextBtn.addEventListener("click", () => {
    if (!answers[current]) return;
    current++;
    if (current <= questions.length) render();
  });

  render();
</script>